APP_NAME="Notebook API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Base de données MySQL ───────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=notebook_db
DB_USERNAME=root
DB_PASSWORD=root

# ─── Sanctum ────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001

# ─── CORS ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Session ────────────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── Cache / Queue ──────────────────────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ─── Mail (optionnel) ───────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@notebook.com"
MAIL_FROM_NAME="${APP_NAME}"
